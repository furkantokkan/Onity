<?xml version="1.0" encoding="utf-8"?>
<packages>
  <!-- Onity's Unity layer depends on ZLinq (the only third-party runtime dependency).
       NuGetForUnity (declared in Packages/manifest.json) auto-restores this from
       nuget.org into Assets/Packages/ the first time the project is opened. -->
  <package id="ZLinq" version="1.5.4" manuallyInstalled="true" />
</packages>
